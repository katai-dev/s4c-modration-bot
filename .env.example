# ─────────────────────────────────────────────────────────────────────────────
# Galaxy Handler — Environment Variables Template
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Discord Bot ───────────────────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
CLIENT_TOKEN="your-bot-token-here"

# ── Bot Owner & Developers ────────────────────────────────────────────────────
# Your Discord user ID
OWNER_ID="your-discord-user-id"

# Comma-separated list of developer Discord IDs (include your own)
DEV_IDS="your-id,another-developer-id"

# ── Development Guild ─────────────────────────────────────────────────────────
# Guild ID for dev mode (instant slash command registration)
# Only used when development.enabled = true in config.js
DEV_GUILD_ID="your-dev-server-id"

# ── Logging Webhook (Optional) ────────────────────────────────────────────────
# Discord webhook URL for error/warn remote monitoring
# Leave blank or remove to disable
LOG_WEBHOOK_URL=""

# ── Databases ─────────────────────────────────────────────────────────────────
# MongoDB connection string (Required for settings and dynamic configurations)
# Example: mongodb://localhost:27017/galaxy
MONGODB_URI=""

# Redis connection string (Required for distributed caching & sharding)
# Example: redis://localhost:6379
REDIS_URI=""
